&CONTROL
    calculation = 'bands'
    etot_conv_thr =   1.0000000000d-06
    forc_conv_thr =   2.0000000000d-05
    outdir = './tmp'
    prefix = 'MoS2'
    pseudo_dir = '../pseudo/'
    wf_collect  = .true.
!   tprnfor = .true.
!   tstress = .true.
    verbosity = 'high'
/
&SYSTEM
    nspin = 4   ! 1: non-polaized 2: spin-polarized 4: spin-polarzed, noncollinear
    degauss =   7.3498618000d-03
    ecutrho =   800
    ecutwfc =   8.0000000000d+01
    ibrav = 4
    celldm(1) = 5.937701271208027 
    celldm(3) = 8.000000000000000
    nat = 3
    nosym = .false.
    ntyp = 2
    occupations = 'smearing'
    smearing = 'gauss'
    assume_isolated = '2D'
    nbnd = 80
    noncolin = .true.
    lspinorb = .true.
/
&ELECTRONS
    conv_thr =   1.0000000000d-15
    electron_maxstep = 200
    mixing_mode = 'plain'
    mixing_beta = 0.7
    diagonalization = 'david'
    diago_full_acc = .true.
/
&IONS
/
&CELL
    press_conv_thr = 0.01
    press = 0.D0
!    cell_dynamics = 'bfgs'
!    cell_dofree = '2Dxy'  ! 3d: all 2d: 2Dxy
/
