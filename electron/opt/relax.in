&CONTROL
    calculation = 'vc-relax'
    etot_conv_thr =   1.0000000000d-06
    forc_conv_thr =   2.0000000000d-05
    outdir = './tmp'
    prefix = 'MoS2'
    pseudo_dir = '../pseudo/'
    wf_collect  = .true.
!   tprnfor = .true.
!   tstress = .true.
    verbosity = 'high'
/
&SYSTEM
    nspin = 4   ! 1: non-polaized 2: spin-polarized 4: spin-polarzed, noncollinear
    degauss =   7.3498618000d-03
    ecutrho =   800
    ecutwfc =   8.0000000000d+01
    ibrav = 4
    celldm(1) = 5.937567475757923 
    celldm(3) = 8.000000000000000
    nat = 3
    nosym = .false.
    ntyp = 2
    occupations = 'smearing'
    smearing = 'gauss'
    assume_isolated = '2D'
    noncolin = .true.
    lspinorb = .true.
/
&ELECTRONS
    conv_thr =   1.0000000000d-12
    electron_maxstep = 200
    mixing_mode = 'plain'
    mixing_beta = 0.7
    diagonalization = 'david'
    diago_full_acc = .true.
/
&IONS
/
&CELL
    press_conv_thr = 0.01
    press = 0.D0
    cell_dynamics = 'bfgs'
    cell_dofree = '2Dxy'  ! 3d: all 2d: 2Dxy
/
ATOMIC_SPECIES
S     32.06 S.rel-pbesol-n-rrkjus_psl.1.0.0.UPF
Mo    95.95 Mo.rel-pbesol-spn-rrkjus_psl.1.0.0.UPF 
ATOMIC_POSITIONS crystal
S             0.0000011533        0.9999988467        0.1804608495
S             0.0000011298        0.9999988702        0.3030002942
Mo            0.6666677413        0.3333322886        0.2417305708
K_POINTS automatic
12 12 1 0 0 0
